@model HaagsVertaler.Models.TranslationViewModel

@{
    ViewBag.Current = "Home";
}

<h1>Vertaal Nederlands naar het Haags</h1>
<span>Vetaal Neidâhlans naah ut Haags</span>

@using (Html.BeginForm())
{
	<section class="translate-sections">
		<section class="nederlands-input">
			<div class="form-header">
				<h2>Nederlands</h2>	
				<button type="button" class="js-wis-tekst">Wis tekst</button>
			</div>
				
			@Html.TextAreaFor(f => f.Source, new { placeholder = "Het Nederlands", autofocus = true, @class = "js-nederlands", aria_label = "Nederlandse tekst" })
		</section>
		
		<button type="submit" class="button">Vertaal!</button>

		<section>
			<h2>Haags</h2>
			<div class="haags-resultaat">
				<textarea aria-label="Haagse tekst" class="js-haags" readonly>@(string.IsNullOrEmpty(Model.Result)?"Ut Haags":Model.Result)</textarea> @* Intentionally without whitespace *@
				<button type="button" class="js-kopieer-tekst">Kopieer</button>
			</div>
		</section>
	</section>
}

<a id="chrome-extension-link" class="extension-promo"
   href="https://chromewebstore.google.com/detail/haags-vertaler/fmofgebkdkkeffbnimglnlognlklfdlm"
   target="_blank" rel="noopener">
	<span class="extension-promo__icon">
		<img src="/haags-vertaler-icon.png" alt="Logo van Haags Vertaler" width="56" height="56" />
	</span>
	<span class="extension-promo__text">
		<span class="extension-promo__title">Leis élke website in ut Haags</span>
		<span class="extension-promo__subtitle">Nâh as Chraume-ekstensie!</span>
	</span>
	<span class="extension-promo__cta">
		<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
			<path fill="#EA4335" d="M24 24 L43.05 13 A22 22 0 0 0 4.95 13 Z"/>
			<path fill="#34A853" d="M24 24 L4.95 13 A22 22 0 0 0 24 46 Z"/>
			<path fill="#FBBC05" d="M24 24 L24 46 A22 22 0 0 0 43.05 13 Z"/>
			<circle cx="24" cy="24" r="9.5" fill="#fff"/>
			<circle cx="24" cy="24" r="8" fill="#4285F4"/>
		</svg>
		Toevoege an Chraume
	</span>
</a>
